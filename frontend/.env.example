# OpenAI model ladder (optional; defaults in code)
# Guest: gpt-4o-mini | Free: gpt-5-mini | Pro chat: gpt-5.1
# MODEL_GUEST=gpt-4o-mini
# MODEL_FREE=gpt-5-mini
# MODEL_PRO_CHAT=gpt-5.1

# Debug: log stream route decisions (isGuest, v2Summary, raw path, commander) to console
# DEBUG_CHAT_STREAM=1

# IndexNow (Bing/Yandex compatible URL change notifications)
# Generate a 32-character key in Bing Webmaster Tools or IndexNow, then add it in Vercel.
# INDEXNOW_KEY=
# INDEXNOW_ENABLED=true
# NEXT_PUBLIC_SITE_URL=https://www.manatap.ai
